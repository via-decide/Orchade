// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (Firebase Auth UID)
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - batch: number (optional) - Rollout wave membership (1, 2, or 3)
//
// Collection: transfers
// Document ID: {transferId} (senderUid_receiverUid_dayKey_random)
// Fields:
//   - from: string (required)
//   - to: string (required)
//   - amount: number (required)
//   - protocol: string (required) - "social-transfer-protocol"
//   - dayKey: string (required) - YYYYMMDD
//   - timestamp: timestamp (required)
//
// Collection: stp_daily_limits
// Document ID: {uid_dayKey}
// Fields:
//   - uid: string
//   - dayKey: string
//   - transferCount: number
//   - lastTransferAt: timestamp
//   - displayName: string (optional) - User's public name
//   - email: string (optional) - User's email
//   - credits: number (required) - Current liquid capital
//   - dataSeeds: number (required) - Current genetic data
//   - day: number (required) - Current game day
//   - upgrades: map (required) - Global upgrades state
//   - orchards: list (required) - List of orchards and their plants
//   - batch: number (optional) - Rollout wave membership (1, 2, or 3)
//   - createdAt: timestamp (optional) - When the user was created
//
// Collection: transfers
// Document ID: {transferId} (senderUid_receiverUid_windowKey)
// Fields:
//   - from: string (required) - Sender UID
//   - to: string (required) - Receiver UID
//   - amount: number (required) - Amount of credits transferred
//   - protocol: string (required) - Must be "social-transfer-protocol"
//   - windowKey: string (required) - YYYYMMDDHHmm (minute bucket)
//   - timestamp: timestamp (required) - When the transfer occurred
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "daxini2404@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.credits is number && data.credits >= 0 &&
             data.dataSeeds is number && data.dataSeeds >= 0 &&
             data.day is number && data.day >= 1 &&
             data.orchards is list &&
             data.upgrades is map;
    }

    function isBatchUser(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)) &&
             get(/databases/$(database)/documents/users/$(userId)).data.batch in [1, 2, 3];
    }

    function isSocialTransferProtocol(data) {
      return data.protocol == 'social-transfer-protocol' &&
             data.dayKey is string &&
             data.dayKey.matches('^[0-9]{8}$');
    }

    function stpCounterPath(data) {
      return /databases/$(database)/documents/stp_daily_limits/$(request.auth.uid + '_' + data.dayKey);
    }

    function isWithinDailyLimit(data) {
      let counter = getAfter(stpCounterPath(data)).data;
      return counter.uid == request.auth.uid &&
             counter.dayKey == data.dayKey &&
             counter.transferCount is number &&
             counter.transferCount <= 5 &&
             counter.lastTransferAt == request.time;
             data.windowKey is string &&
             data.windowKey.matches('^[0-9]{12}$');
    }

    function isRateLimitedTransfer(transferId, data) {
      // Allow at most one transfer per minute bucket for each sender->receiver pair.
      // transferId must be sender_receiver_YYYYMMDDHHmm.
      return transferId == (data.from + '_' + data.to + '_' + data.windowKey);
    }

    function isValidTransfer(transferId, data) {
      return data.from == request.auth.uid &&
             data.to is string && data.to != request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.timestamp == request.time &&
             transferId.matches('^' + data.from + '_' + data.to + '_' + data.dayKey + '_.+$') &&
             isBatchUser(data.from) &&
             isBatchUser(data.to) &&
             isSocialTransferProtocol(data) &&
             isWithinDailyLimit(data);
             isBatchUser(data.from) &&
             isBatchUser(data.to) &&
             isSocialTransferProtocol(data) &&
             isRateLimitedTransfer(transferId, data);
    }

    function isCreditTransferUpdate(userId) {
      let diff = request.resource.data.diff(resource.data);
      let transferId = request.auth.uid + '_' + userId;
      let transferPath = /databases/$(database)/documents/transfers/$(transferId);

      return diff.affectedKeys().hasOnly(['credits']) &&
             request.resource.data.credits == resource.data.credits + getAfter(transferPath).data.amount &&
             getAfter(transferPath).data.from == request.auth.uid &&
             getAfter(transferPath).data.to == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Allow reading the leaderboard (Top 10)
      allow list: if isAuthenticated() &&
                    request.query.limit <= 50 &&
                    request.query.orderBy[0].path == 'credits' &&
                    request.query.orderBy[0].direction == 'DESC';

      // Allow searching for other users by UID for transfers (only UID and displayName)
      allow list: if isAuthenticated() &&
                    request.query.limit <= 1 &&
                    request.query.filters.size() == 1 &&
                    request.query.filters[0].op == '==' &&
                    request.query.filters[0].path == 'uid';

      allow create: if isOwner(userId) &&
                      isValidUser(request.resource.data) &&
                      (!('role' in request.resource.data) || request.resource.data.role == 'player');

      allow update: if (isOwner(userId) &&
                       isValidUser(request.resource.data) &&
                       request.resource.data.role == resource.data.role) ||
                      isCreditTransferUpdate(userId) ||
                      isAdmin();
    }

    match /stp_daily_limits/{counterId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.dayKey is string &&
        request.resource.data.dayKey.matches('^[0-9]{8}$') &&
        request.resource.data.transferCount is number &&
        request.resource.data.transferCount <= 5 &&
        request.resource.data.lastTransferAt == request.time;
      allow delete: if false;
    }

    match /transfers/{transferId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to ||
        isAdmin()
      );

      allow create: if isAuthenticated() && isValidTransfer(transferId, request.resource.data);
      // Social Transfer Protocol: authenticated Batch 1-3 users with per-minute pair rate limits.
      allow create: if isAuthenticated() && isValidTransfer(transferId, request.resource.data);

      // Transfers are immutable
      allow update, delete: if false;
    }

    match /system/global_stats {
      allow read: if isAuthenticated();

      // Only authenticated users can update stats (usually via batch with their own actions)
      // We should ideally restrict this more, but for a game prototype, this is okay.
      allow write: if isAuthenticated();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
