{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user credits, genetic data, and game state.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's public name" },
        "email": { "type": "string", "description": "User's email" },
        "credits": { "type": "number", "description": "Current liquid capital" },
        "dataSeeds": { "type": "number", "description": "Current genetic data" },
        "day": { "type": "number", "description": "Current game day" },
        "upgrades": { "type": "object", "description": "Global upgrades state" },
        "tools": { "type": "array", "description": "List of owned tools and their levels" },
        "orchards": { "type": "array", "description": "List of orchards and their plants" },
        "weather": { "type": "object", "description": "Current weather conditions" },
        "role": { "type": "string", "enum": ["player", "admin"], "description": "User role" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last time the state was saved" },
        "discoveredTypes": { "type": "array", "items": { "type": "string" }, "description": "List of discovered plant types" }
      },
      "required": ["uid", "credits", "dataSeeds", "day", "orchards", "tools", "weather", "role", "discoveredTypes"]
    },
    "Transfer": {
      "title": "Credit Transfer",
      "description": "Record of a credit transfer between users.",
      "type": "object",
      "properties": {
        "from": { "type": "string", "description": "Sender UID" },
        "to": { "type": "string", "description": "Receiver UID" },
        "amount": { "type": "number", "description": "Amount of credits transferred" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the transfer occurred" }
      },
      "required": ["from", "to", "amount", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user game state."
    },
    "/transfers/{transferId}": {
      "schema": "Transfer",
      "description": "Log of all credit transfers."
    }
  }
}
