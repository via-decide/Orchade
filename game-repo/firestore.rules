// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (Firebase Auth UID)
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - displayName: string (optional) - User's public name
//   - email: string (optional) - User's email
//   - credits: number (required) - Current liquid capital
//   - dataSeeds: number (required) - Current genetic data
//   - day: number (required) - Current game day
//   - upgrades: map (required) - Global upgrades state
//   - tools: list (required) - List of owned tools and their levels
//   - orchards: list (required) - List of orchards and their plants
//   - weather: map (required) - Current weather conditions
//   - createdAt: timestamp (optional) - When the user was created
//
// Collection: transfers
// Document ID: {transferId} (Auto-generated)
// Fields:
//   - from: string (required) - Sender UID
//   - to: string (required) - Receiver UID
//   - amount: number (required) - Amount of credits transferred
//   - timestamp: timestamp (required) - When the transfer occurred
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "via.decide@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidPlant(plant) {
      return plant == null || (
        plant.id is string && plant.id.size() < 50 &&
        plant.type is string && plant.type.size() < 50 &&
        plant.rootStrength is number &&
        plant.water is number &&
        plant.nutrients is number &&
        plant.stress is number &&
        plant.pests is number &&
        plant.pestImmunity is number &&
        plant.stageIndex is number &&
        plant.isHarvestable is bool &&
        (plant.get('rarity', 'Common') in ['Common', 'Uncommon', 'Rare', 'Epic', 'Legendary']) &&
        (plant.get('growthSpeedMultiplier', 1) is number) &&
        (plant.get('yieldMultiplier', 1) is number) &&
        (!('color' in plant) || plant.color is string)
      );
    }

    function isValidOrchard(orchard) {
      return orchard.id is string && orchard.id.size() < 50 &&
             orchard.name is string && orchard.name.size() < 100 &&
             orchard.plants is list && orchard.plants.size() == 9 &&
             orchard.plants.all(p, isValidPlant(p)) &&
             (orchard.get('isUnlocked', true) is bool) &&
             (orchard.get('unlockCost', 0) is number);
    }

    function isValidUser(data) {
      return (data.get('uid', request.auth.uid) == request.auth.uid) &&
             (data.get('credits', 0) is number) &&
             (data.get('dataSeeds', 0) is number) &&
             (data.get('day', 1) is number) &&
             (data.get('orchards', []) is list) &&
             (data.get('orchards', []).size() <= 10) &&
             (data.get('orchards', []).all(o, isValidOrchard(o))) &&
             (data.get('upgrades', {}) is map) &&
             (data.get('tools', []) is list) &&
             (data.get('weather', {}) is map) &&
             (data.get('role', 'player') in ['player', 'admin']) &&
             (!('lastUpdated' in data) || data.lastUpdated is timestamp) &&
             (data.get('discoveredTypes', []) is list);
    }

    function isValidTransfer(data) {
      return data.from == request.auth.uid &&
             data.to is string && data.to != request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.timestamp == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow searching for other users by UID for transfers, and leaderboard queries
      allow list: if isAuthenticated() && (
                    (request.query.limit <= 1 && 
                     request.query.filters.size() == 1 && 
                     request.query.filters[0].op == '==' && 
                     request.query.filters[0].path == 'uid') ||
                    (request.query.limit <= 10 && 
                     (request.query.orders[0].path == 'credits' || request.query.orders[0].path == 'dataSeeds'))
                  );

      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      (request.resource.data.get('role', 'player') == 'player');

      allow update: if isAuthenticated() && (
                      (isOwner(userId) && 
                       uidUnchanged() &&
                       isValidUser(request.resource.data) &&
                       request.resource.data.get('role', resource.data.get('role', 'player')) == resource.data.get('role', 'player')) || 
                      (!isOwner(userId) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['credits']) &&
                       request.resource.data.credits > resource.data.credits &&
                       (request.resource.data.credits - resource.data.credits) == 
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.credits - 
                        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.credits)
                      ) ||
                      isAdmin()
                    );
    }

    match /transfers/{transferId} {
      // Only admins or involved parties can read transfers
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.from || 
        request.auth.uid == resource.data.to || 
        isAdmin()
      );

      // Only authenticated users can create transfers, and they must be the sender
      allow create: if isAuthenticated() && isValidTransfer(request.resource.data);
      
      // Transfers are immutable
      allow update, delete: if false;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
